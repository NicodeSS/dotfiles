#!/bin/bash
# Install TPM plugins automatically after chezmoi apply
# chezmoi:run-onchange-hash: {{ joinPath .chezmoi.sourceDir "dot_tmux/tmux.conf" | include | sha256sum }}

set -euo pipefail

if ! command -v tmux &>/dev/null; then
  echo "tmux not found, skipping TPM plugin installation"
  exit 0
fi

TPM_DIR="$HOME/.tmux/plugins/tpm"

if [ ! -d "$TPM_DIR" ]; then
  echo "TPM not found at $TPM_DIR, skipping plugin installation"
  exit 0
fi

echo "Installing TPM plugins..."
tmux new -d -s __chezmoi_tpm >/dev/null 2>&1 || true
tmux set-environment -g TMUX_PLUGIN_MANAGER_PATH "~/.tmux/plugins"
"$TPM_DIR/bin/install_plugins" || true
tmux kill-session -t __chezmoi_tpm >/dev/null 2>&1 || true
echo "TPM plugins installed"
